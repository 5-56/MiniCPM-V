<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_gradient"
    android:gravity="center">

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/voice_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="设置"
                android:tint="@color/white" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 主要内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <!-- 语音波形动画 -->
            <ImageView
                android:id="@+id/image_voice_wave"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/ic_voice_wave"
                android:contentDescription="语音波形"
                android:visibility="gone"
                android:layout_marginBottom="32dp" />

            <!-- 状态文本 -->
            <TextView
                android:id="@+id/text_voice_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_ready"
                android:textSize="18sp"
                android:textColor="@color/primary_text"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- 语音按钮 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/primary_color">

                <Button
                    android:id="@+id/btn_voice_start"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/voice_button"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:background="@drawable/button_circle_primary"
                    android:gravity="center" />

            </com.google.android.material.card.MaterialCardView>

            <!-- 停止按钮 -->
            <Button
                android:id="@+id/btn_voice_stop"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:text="@string/voice_stop"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/button_circle_danger"
                android:visibility="gone"
                android:layout_marginBottom="32dp" />

            <!-- 转录文本区域 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="语音转录"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/text_voice_transcript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:minHeight="100dp"
                        android:background="@drawable/text_background"
                        android:padding="12dp"
                        android:gravity="top" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 功能按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_voice_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_clear"
                    android:textColor="@color/primary_color"
                    android:background="@drawable/button_outline"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 底部提示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="长按开始录音，松开结束录音"
            android:textSize="12sp"
            android:textColor="@color/secondary_text"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支持中英文语音识别和合成"
            android:textSize="12sp"
            android:textColor="@color/secondary_text"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</LinearLayout>